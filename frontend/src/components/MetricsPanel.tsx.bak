'use client';

import { Activity, TrendingUp, AlertTriangle, Target, X } from 'lucide-react';
import { estadosMexico, modelMetrics } from '@/lib/mockDataMexico';
import { useState } from 'react';
import { useLanguage } from '@/contexts/LanguageContext';

export default function MetricsPanel() {
  const [modalOpen, setModalOpen] = useState<string | null>(null);
  const { t } = useLanguage();
  
  const totalCasosActuales = estadosMexico.reduce((sum, e) => sum + e.casos_actuales, 0);
  const totalCasosPredichos = estadosMexico.reduce((sum, e) => sum + e.casos_predichos_semana4, 0);
  const aumentoPromedio = Math.round(
    estadosMexico.reduce((sum, e) => sum + e.aumento_porcentaje, 0) / estadosMexico.length
  );
  const estadosEnRiesgo = estadosMexico.filter(e => e.riesgo === 'ALTO' || e.riesgo === 'CRÍTICO').length;

  return (
    <>
    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
      {/* Casos Actuales */}
      <div onClick={() => setModalOpen('casos')} className="bg-[#1A1F2E] rounded-lg p-4 border border-[#2D3748] hover:border-blue-500/50 transition-all cursor-pointer">
        <div className="flex items-center justify-between mb-2">
          <div className="w-10 h-10 bg-blue-500/10 rounded-lg flex items-center justify-center">
            <Activity size={20} className="text-blue-400" />
          </div>
          <span className="text-xs text-slate-500">{t('metrics.thisWeek')}</span>
        </div>
        <p className="text-2xl font-bold text-white">{totalCasosActuales.toLocaleString()}</p>
        <p className="text-xs text-slate-400 mt-1">{t('metrics.confirmed')}</p>
      </div>

      {/* Predicción 4 Semanas */}
      <div onClick={() => setModalOpen('prediccion')} className="bg-[#1A1F2E] rounded-lg p-4 border border-[#2D3748] hover:border-purple-500/50 transition-all cursor-pointer">
        <div className="flex items-center justify-between mb-2">
          <div className="w-10 h-10 bg-purple-500/10 rounded-lg flex items-center justify-center">
            <TrendingUp size={20} className="text-purple-400" />
          </div>
          <span className="text-xs text-slate-500">{t('metrics.week4')}</span>
        </div>
        <p className="text-2xl font-bold text-white">{totalCasosPredichos.toLocaleString()}</p>
        <p className="text-xs text-slate-400 mt-1">{t('metrics.predicted')}</p>
      </div>

      {/* Aumento Promedio */}
      <div onClick={() => setModalOpen('tendencia')} className="bg-[#1A1F2E] rounded-lg p-4 border border-[#2D3748] hover:border-orange-500/50 transition-all cursor-pointer">
        <div className="flex items-center justify-between mb-2">
          <div className="w-10 h-10 bg-orange-500/10 rounded-lg flex items-center justify-center">
            <AlertTriangle size={20} className="text-orange-400" />
          </div>
          <span className="text-xs text-slate-500">{t('metrics.trend')}</span>
        </div>
        <p className="text-2xl font-bold text-orange-400">+{aumentoPromedio}%</p>
        <p className="text-xs text-slate-400 mt-1">{t('metrics.avgIncrease')}</p>
      </div>

      {/* Estados en Riesgo */}
      <div onClick={() => setModalOpen('alertas')} className="bg-[#1A1F2E] rounded-lg p-4 border border-[#2D3748] hover:border-red-500/50 transition-all cursor-pointer">
        <div className="flex items-center justify-between mb-2">
          <div className="w-10 h-10 bg-red-500/10 rounded-lg flex items-center justify-center">
            <AlertTriangle size={20} className="text-red-400" />
          </div>
          <span className="text-xs text-slate-500">{t('metrics.alerts')}</span>
        </div>
        <p className="text-2xl font-bold text-red-400">{estadosEnRiesgo}</p>
        <p className="text-xs text-slate-400 mt-1">{t('metrics.highRisk')}</p>
      </div>

      {/* Precisión del Modelo */}
      <div onClick={() => setModalOpen('precision')} className="bg-gradient-to-br from-green-500/10 to-emerald-500/10 rounded-lg p-4 border border-green-500/30 hover:border-green-500/50 transition-all cursor-pointer">
        <div className="flex items-center justify-between mb-2">
          <div className="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
            <Target size={20} className="text-green-400" />
          </div>
          <span className="text-xs text-green-400 font-semibold">{t('metrics.excellent')}</span>
        </div>
        <p className="text-2xl font-bold text-white">94%</p>
        <p className="text-xs text-slate-400 mt-1">{t('metrics.modelAccuracy')}</p>
        <div className="mt-2 h-1 bg-[#2D3748] rounded-full overflow-hidden">
          <div className="h-full bg-green-500" style={{ width: '94%' }}></div>
        </div>
        <p className="text-xs text-slate-500 mt-2">WAPE: 0.12 | MAPE: 0.15</p>
      </div>
    </div>

    {/* Modales */}
    {modalOpen && (
      <div onClick={() => setModalOpen(null)} className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
        <div onClick={(e) => e.stopPropagation()} className="bg-[#1A1F2E] rounded-lg p-6 max-w-2xl w-full max-h-[90vh] overflow-y-auto border border-[#2D3748]">
          <div className="flex justify-between items-center mb-4">
            <h3 className="text-xl font-bold text-white">
              {modalOpen === 'precision' && 'Precisión del Modelo'}
              {modalOpen === 'casos' && 'Casos Confirmados'}
              {modalOpen === 'prediccion' && 'Predicción de Casos'}
              {modalOpen === 'tendencia' && 'Análisis de {t('metrics.trend')}'}
              {modalOpen === 'alertas' && 'Estados en Alerta'}
            </h3>
            <button onClick={() => setModalOpen(null)} className="text-slate-400 hover:text-white">
              <X size={24} />
            </button>
          </div>

          {modalOpen === 'precision' && (
            <div className="space-y-4">
              <div className="bg-[#0F1419] rounded-lg p-4 border border-green-500/30">
                <p className="text-sm text-slate-400 mb-2">SageMaker Canvas - DeepAR+</p>
                <div className="flex items-end gap-4">
                  <div className="text-5xl font-bold text-white">88%</div>
                  <div className="text-green-400 font-semibold mb-2">{t('metrics.excellent')}</div>
                </div>
              </div>

              <div className="grid grid-cols-3 gap-4">
                <div className="bg-[#0F1419] rounded-lg p-4">
                  <p className="text-xs text-slate-500 mb-1">WAPE</p>
                  <p className="text-2xl font-bold text-white">0.12</p>
                  <p className="text-xs text-slate-400 mt-1">Objetivo: &lt; 0.15</p>
                </div>
                <div className="bg-[#0F1419] rounded-lg p-4">
                  <p className="text-xs text-slate-500 mb-1">MAPE</p>
                  <p className="text-2xl font-bold text-white">0.15</p>
                  <p className="text-xs text-slate-400 mt-1">Objetivo: &lt; 0.20</p>
                </div>
                <div className="bg-[#0F1419] rounded-lg p-4">
                  <p className="text-xs text-slate-500 mb-1">RMSE</p>
                  <p className="text-2xl font-bold text-white">42.3</p>
                  <p className="text-xs text-slate-400 mt-1">casos</p>
                </div>
              </div>

              <div className="bg-[#0F1419] rounded-lg p-4">
                <h4 className="text-sm font-semibold text-white mb-3">Cómo Calculamos la Precisión</h4>
                <div className="space-y-2 text-sm text-slate-300">
                  <p><strong className="text-white">WAPE (0.12):</strong> Error promedio ponderado del 12%, excelente para epidemiología.</p>
                  <p><strong className="text-white">MAPE (0.15):</strong> Desviación promedio del 15% del valor real.</p>
                  <p><strong className="text-white">RMSE (42.3):</strong> Desviación promedio de ±42 casos del valor real.</p>
                </div>
              </div>

              <div className="grid grid-cols-3 gap-4">
                <div className="bg-[#0F1419] rounded-lg p-4 text-center">
                  <div className="text-2xl mb-1">1️⃣</div>
                  <p className="text-xs font-semibold text-white">Backtesting</p>
                  <p className="text-xs text-slate-400 mt-1">3 ventanas temporales</p>
                </div>
                <div className="bg-[#0F1419] rounded-lg p-4 text-center">
                  <div className="text-2xl mb-1">2️⃣</div>
                  <p className="text-xs font-semibold text-white">Cross-Validation</p>
                  <p className="text-xs text-slate-400 mt-1">5-fold</p>
                </div>
                <div className="bg-[#0F1419] rounded-lg p-4 text-center">
                  <div className="text-2xl mb-1">3️⃣</div>
                  <p className="text-xs font-semibold text-white">Intervalos</p>
                  <p className="text-xs text-slate-400 mt-1">P10-P90 (90%)</p>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-4 text-sm">
                <div className="flex justify-between"><span className="text-slate-400">Algoritmo:</span><span className="text-white font-semibold">DeepAR+</span></div>
                <div className="flex justify-between"><span className="text-slate-400">Entrenamiento:</span><span className="text-white">3.2 horas</span></div>
                <div className="flex justify-between"><span className="text-slate-400">Actualización:</span><span className="text-white">Hace 2 horas</span></div>
                <div className="flex justify-between"><span className="text-slate-400">Tipo:</span><span className="text-white">Quick Build</span></div>
              </div>
            </div>
          )}

          {modalOpen === 'casos' && (
            <div className="space-y-4">
              <div className="bg-[#0F1419] rounded-lg p-4">
                <p className="text-4xl font-bold text-white mb-2">{totalCasosActuales.toLocaleString()}</p>
                <p className="text-slate-400">Casos confirmados esta semana</p>
              </div>
              <div className="space-y-2">
                {estadosMexico.slice(0, 5).map(e => (
                  <div key={e.name} className="flex justify-between items-center bg-[#0F1419] rounded p-3">
                    <span className="text-white">{e.name}</span>
                    <span className="text-blue-400 font-semibold">{e.casos_actuales.toLocaleString()}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {modalOpen === 'prediccion' && (
            <div className="space-y-4">
              <div className="bg-[#0F1419] rounded-lg p-4">
                <p className="text-4xl font-bold text-white mb-2">{totalCasosPredichos.toLocaleString()}</p>
                <p className="text-slate-400">{t('metrics.predicted')} para semana 4</p>
              </div>
              <div className="space-y-2">
                {estadosMexico.slice(0, 5).map(e => (
                  <div key={e.name} className="flex justify-between items-center bg-[#0F1419] rounded p-3">
                    <span className="text-white">{e.name}</span>
                    <span className="text-purple-400 font-semibold">{e.casos_predichos_semana4.toLocaleString()}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {modalOpen === 'tendencia' && (
            <div className="space-y-4">
              <div className="bg-[#0F1419] rounded-lg p-4">
                <p className="text-4xl font-bold text-orange-400 mb-2">+{aumentoPromedio}%</p>
                <p className="text-slate-400">{t('metrics.avgIncrease')} proyectado</p>
              </div>
              <div className="space-y-2">
                {estadosMexico.slice(0, 5).map(e => (
                  <div key={e.name} className="flex justify-between items-center bg-[#0F1419] rounded p-3">
                    <span className="text-white">{e.name}</span>
                    <span className="text-orange-400 font-semibold">+{e.aumento_porcentaje}%</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {modalOpen === 'alertas' && (
            <div className="space-y-4">
              <div className="bg-[#0F1419] rounded-lg p-4">
                <p className="text-4xl font-bold text-red-400 mb-2">{estadosEnRiesgo}</p>
                <p className="text-slate-400">{t('metrics.highRisk')} o crítico</p>
              </div>
              <div className="space-y-2">
                {estadosMexico.filter(e => e.riesgo === 'ALTO' || e.riesgo === 'CRÍTICO').map(e => (
                  <div key={e.name} className="flex justify-between items-center bg-[#0F1419] rounded p-3">
                    <span className="text-white">{e.name}</span>
                    <span className={`font-semibold ${e.riesgo === 'CRÍTICO' ? 'text-red-500' : 'text-orange-400'}`}>
                      {e.riesgo}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <button onClick={() => setModalOpen(null)} className="mt-6 w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors">
            Entendido
          </button>
        </div>
      </div>
    )}
    </>
  );
}
